---
import "../styles/global.css";

const {
  title = "jihad khairallah architects.",
  description = "minimalist architecture and interior architecture. a beirut practice founded in 1998, working across lebanon, the levant, and the gulf.",
  image = "/studio/founders.jpg",
} = Astro.props;

const site = Astro.site ?? new URL("https://jihadk.com");
const canonical = new URL(Astro.url.pathname, site).href;
const ogImage = new URL(image, site).href;
const logo = new URL("/jka-monogram.png", site).href;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/png" href="/jka-monogram.png" />

  <!-- open graph — how the link renders when shared (linkedin, instagram, whatsapp) -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="jihad khairallah architects" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- twitter / x card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Questrial&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": ["ProfessionalService", "ArchitecturalService"],
  "name": "jihad khairallah architects",
  "alternateName": "JKA",
  "url": "https://jihadk.com",
  "email": "mail@jihadk.com",
  "foundingDate": "1998",
  "founder": { "@type": "Person", "name": "Jihad Khairallah" },
  "description": "minimalist architecture and interior architecture practice founded in beirut in 1998, working across lebanon, the levant, and the gulf.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Riverside 2404",
    "addressLocality": "Sin El Fil",
    "addressRegion": "Beirut",
    "addressCountry": "LB"
  },
  "areaServed": ["Lebanon", "United Arab Emirates", "Saudi Arabia", "Qatar"],
  "knowsAbout": ["residential architecture", "interior architecture", "bespoke furniture design"],
  "logo": logo,
  "telephone": "+961 3 111 354",
  "sameAs": [
    "https://instagram.com/jihadkhairallaharchitects",
    "https://facebook.com/jihadkhairallaharchitects",
    "https://linkedin.com/in/jihadkhairallah"
  ]
}) } />
</head>
<body style="background-color: #e6e6e6;">

  <nav class="global-navigation-header">
    <div class="logo-container">
      <a class="brand-lockup" href="/" aria-label="jihad khairallah architects — home">
        <img src="/jka-monogram.png" alt="" class="brand-logo" />
        <span class="lockup-jihad">jihad</span>
        <span class="lockup-name">khairallah architects</span>
      </a>
    </div>
    <div class="extended-menu-links">
      <a href="/projects">projects</a>
      <a href="/news">news</a>
      <a href="/products">products</a>
      <a href="/studio">studio</a>
      <a href="/inquiries">inquiries</a>
    </div>
  </nav>

  <slot />

  <style>
    /* ===== global navigation — permanently extended, no drawer ===== */
    .global-navigation-header {
      position: absolute; top: 0; left: 0; width: 100%;
      display: flex; justify-content: space-between; align-items: center;
      padding: 32px 40px; box-sizing: border-box;
      z-index: 100; background: transparent;
      pointer-events: none;                 /* transparent gaps don't block content beneath */
    }
    .global-navigation-header a { pointer-events: auto; }

    .logo-container { display: flex; align-items: center; }

    /* brand lockup: monogram left, "jihad" top-right, "khairallah architects" below.
       both text lines are pinned to the same right edge, so the last letter of
       "architects" sits directly under the last letter of "jihad". */
    .brand-lockup {
      display: inline-grid;
      grid-template-columns: auto auto;   /* logo | jihad */
      grid-template-rows: auto auto;
      column-gap: 16px; row-gap: 5px;
      align-items: center;
      text-decoration: none; color: var(--ink); line-height: 1;
    }
    .brand-lockup .brand-logo { grid-column: 1; grid-row: 1; display: block; height: clamp(44px, 5.2vw, 57px); width: auto; }
    .brand-lockup .lockup-jihad {
      grid-column: 2; grid-row: 1; justify-self: end; align-self: end;
      font-size: 18px; letter-spacing: .14em; text-transform: lowercase;
    }
    .brand-lockup .lockup-name {
      grid-column: 1 / -1; grid-row: 2; justify-self: end; white-space: nowrap;
      font-size: 17px; letter-spacing: .14em; text-transform: lowercase;
    }

    .extended-menu-links { display: flex; align-items: center; gap: 32px; }
    .extended-menu-links a {
      font-size: clamp(0.85rem, 1.2vw, 1rem);
      font-weight: 300; letter-spacing: 0.06em; text-transform: lowercase;
      color: var(--trace);                  /* muted monochrome gray — reads on light grounds */
      text-decoration: none;
      transition: color 0.4s ease, opacity 0.4s ease;
    }
    .extended-menu-links a:hover { color: var(--ink); }

    /* mobile — words wrap / scale down, never hide behind a symbol */
    @media (max-width: 680px) {
      .global-navigation-header { padding: 22px 24px; }
      .extended-menu-links { gap: 18px; }
      .extended-menu-links a { font-size: 0.82rem; letter-spacing: 0.04em; }
    }
    @media (max-width: 460px) {
      .global-navigation-header { flex-direction: column; align-items: flex-start; gap: 14px; padding: 18px 20px; }
      .extended-menu-links { gap: 16px 18px; flex-wrap: wrap; }
    }
  </style>

  <script>
    // footer copyright year — always the live calendar year, no rebuild needed
    document.querySelectorAll('.year').forEach((el) => { el.textContent = String(new Date().getFullYear()); });

    // the interface wake
    const wake = () => document.body.classList.add('awake');
    window.addEventListener('mousemove', wake, { once: true });
    window.addEventListener('scroll', wake, { once: true });
    window.addEventListener('touchstart', wake, { once: true });

    // the quiet settle — content reveal on scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((en) => {
        if (en.isIntersecting) { en.target.classList.add('in'); observer.unobserve(en.target); }
      });
    }, { threshold: 0.01 });
    document.querySelectorAll('.settle').forEach((el) => observer.observe(el));
  </script>

</body>
</html>
