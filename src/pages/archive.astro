---
import Base from "../layouts/Base.astro";
import { archiveOnlyGrid } from "../data/projects";
---
<Base title="earlier work — jihad khairallah architects"
      description="the historical archive of jka — projects from the practice's founding era, beirut, 1998–2010.">
  <div class="projects-head"></div>
  <div class="cms-era-threshold" style="margin-top:0">earlier work</div>
  <section class="projects-grid settle">
    {archiveOnlyGrid.map((p) => (
      <a class="project-card" href="/projects" aria-label={p.name}>
        <div class="image-wrapper">
          <span class="plate-label">[ {p.name} ]</span>
          <div class="metadata-overlay">
            <span class="project-meta-text">{p.name}{p.year && `, ${p.year}`}</span>
          </div>
        </div>
      </a>
    ))}
  </section>
  <div class="silence-module"></div>
  <a class="commission-line" href="/projects"><span>view all projects</span><span>→</span></a>
  <footer class="site-footer">
    <a class="brand-logo-link" href="/" aria-label="jka — home">
      <img src="/jka-monogram.png" alt="jka" class="brand-logo footer" />
    </a>
    <a class="trace" href="mailto:mail@jihadk.com">mail@jihadk.com</a>
    <nav class="footer-social" aria-label="social links">
      <a href="https://instagram.com/jihadkhairallaharchitects" target="_blank" rel="noopener noreferrer" aria-label="instagram"><img src="/icon-instagram.png" alt="" class="social-icon" /></a>
      <a href="https://facebook.com/jihadkhairallaharchitects" target="_blank" rel="noopener noreferrer" aria-label="facebook"><img src="/icon-facebook.png" alt="" class="social-icon" /></a>
      <a href="https://linkedin.com/in/jihadkhairallah" target="_blank" rel="noopener noreferrer" aria-label="linkedin"><img src="/icon-linkedin.png" alt="" class="social-icon" /></a>
    </nav>
    <span class="trace copyright">© jka — beirut, est. 1998</span>
  </footer>
</Base>