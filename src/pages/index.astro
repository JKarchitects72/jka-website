  </main>
  <script>
  const track = document.getElementById('slatTrack');
  const edgeL = document.getElementById('edgeLeft');
  const edgeR = document.getElementById('edgeRight');

  if (track && edgeL && edgeR) {
    const slats = Array.from(track.querySelectorAll('.slat'));
    const VISIBLE = 6, STEP = 5, COOLDOWN = 750;
    let frameStart = 0;
    let locked = false;

    function slotWidth() {
      const gap = 24;
      return (track.parentElement.clientWidth - (VISIBLE - 1) * gap) / VISIBLE + gap;
    }
    function maxStart() { return Math.max(0, slats.length - VISIBLE); }

    function shiftTo(start) {
      frameStart = Math.min(Math.max(0, start), maxStart());
      track.style.transform = `translateX(${-frameStart * slotWidth()}px)`;
    }

    function move(direction) {            // +1 forward, -1 backward
      if (locked) return;
      locked = true;

      if (direction > 0) {
        frameStart >= maxStart() ? shiftTo(0)                    // 18 → wrap home to 1
                                 : shiftTo(frameStart + STEP);   // advance 5
      } else {
        frameStart <= 0 ? shiftTo(maxStart())                    // 1 → wrap to the end (… 18)
                        : shiftTo(frameStart - STEP);            // retreat 5
      }
      setTimeout(() => { locked = false; }, COOLDOWN);
    }

    edgeR.addEventListener('mouseenter', () => move(1));
    edgeL.addEventListener('mouseenter', () => move(-1));

    /* slat hover = expansion only — every project stays clickable */
    slats.forEach((slat) => {
      slat.addEventListener('mouseenter', () => {
        slats.forEach(s => s.classList.remove('expanded'));
        slat.classList.add('expanded');
      });
      slat.addEventListener('mouseleave', () => slat.classList.remove('expanded'));
    });

    window.addEventListener('resize', () => shiftTo(frameStart));
  }
</script>
</Base>