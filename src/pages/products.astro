---
import Base from "../layouts/Base.astro";
import { products } from "../data/products";
---
<Base title="products — jihad khairallah architects"
      description="the jka objects and product archive — the kōzō and kumo lines.">
  <section class="po-head">
    <h1 class="po-title">products</h1>
  </section>

  <section class="po-gallery">
    {products.map((p) => (
      <a class="po-cell" href={`/products/${p.slug}`}>
        {p.image
          ? <img class="po-img" src={p.image} alt={p.name} loading="lazy" />
          : <span class="po-label">[ {p.name} ]</span>}
        <div class="po-meta"><span>{p.name}</span></div>
      </a>
    ))}
  </section>

  <div class="silence-module"></div>
  <a class="commission-line" href="/inquiries"><span>inquire about a piece</span><span>&rarr;</span></a>

  <footer class="site-footer">
    <a class="brand-logo-link" href="/" aria-label="jka — home">
      <img src="/jka-monogram.png" alt="jka" class="brand-logo footer" />
    </a>
    <a class="trace" href="mailto:mail@jihadk.com">mail@jihadk.com</a>
    <nav class="footer-social" aria-label="social links">
      <a href="https://instagram.com/jihadkhairallaharchitects" target="_blank" rel="noopener noreferrer" aria-label="instagram"><img src="/icon-instagram.png" alt="" class="social-icon" /></a>
      <a href="https://facebook.com/jihadkhairallaharchitects" target="_blank" rel="noopener noreferrer" aria-label="facebook"><img src="/icon-facebook.png" alt="" class="social-icon" /></a>
      <a href="https://linkedin.com/in/jihadkhairallah" target="_blank" rel="noopener noreferrer" aria-label="linkedin"><img src="/icon-linkedin.png" alt="" class="social-icon" /></a>
    </nav>
    <span class="trace copyright">&copy; 1998-<span class="year">{new Date().getFullYear()}</span> by jihad khairallah architects</span>
  </footer>

  <style>
    /* ===== products — scoped to this page ===== */
    .po-head { text-align: center; padding: clamp(104px, 17vh, 200px) var(--inset) 0; }
    .po-title { font-size: clamp(1.1rem, 1.7vw, 1.5rem); font-weight: 300; letter-spacing: 0.05em; color: var(--ink); margin: 0; }

    /* the matrix — 2 columns occupying the centre two of four, zero gutters */
    .po-gallery {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0 !important;
      max-width: 50vw;
      margin: clamp(48px, 8vh, 104px) auto 0;
      padding: 0;
    }

    .po-cell {
      position: relative; aspect-ratio: 4 / 3; overflow: hidden;
      display: block; width: 100%; background: var(--plate);
      text-decoration: none; cursor: pointer;
    }
    .po-label {
      position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
      font-size: var(--type-trace); letter-spacing: 0.1em; color: var(--trace); text-align: center; padding: 0 14px;
    }

    .po-img {
      position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
      transition: filter 0.6s ease, transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .po-cell:hover .po-img { transform: scale(1.04); }

    /* metadata — hidden by default, revealed bottom-left on hover, pure white */
    .po-meta {
      position: absolute; left: 0; right: 0; bottom: 0;
      display: flex; align-items: flex-end;
      padding: 18px 20px; text-align: left;
      opacity: 0; transition: opacity 0.6s ease; pointer-events: none;
      background: linear-gradient(to top, rgba(0, 0, 0, 0.30), rgba(0, 0, 0, 0)); /* soft legibility scrim, not a card */
    }
    .po-cell:hover .po-meta { opacity: 1; }
    .po-meta span { font-size: var(--type-trace); font-weight: 300; letter-spacing: 0.08em; color: #ffffff; text-transform: lowercase; }

    /* responsive — matrix widens on small screens */
    @media (max-width: 900px) { .po-gallery { max-width: 76vw; } }
    @media (max-width: 600px) { .po-gallery { max-width: 100%; } }
  </style>
</Base>
