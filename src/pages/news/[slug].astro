---
import Base from "../../layouts/Base.astro";
import { news } from "../../data/news";

export function getStaticPaths() {
  return news.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
const dateRange = item.dateStart ? (item.dateEnd ? `${item.dateStart} - ${item.dateEnd}` : item.dateStart) : "";
const paragraphs = item.body.split("\n\n");
---
<Base title={`${item.title} — jihad khairallah architects`} description={item.description}>
  <article class="nd">
    <!-- headline -->
    <header class="nd-head">
      <div class="nd-eyebrow">
        <span>{item.category}</span>{item.dateStart && (<><span class="nd-dot">·</span><span>{dateRange}</span></>)}
      </div>
      <h1 class="nd-title">{item.title}</h1>
    </header>

    <!-- film (vimeo) -->
    {item.vimeoId && (
      <div class="nd-video">
        <div class="nd-video-frame">
          <iframe
            src={`https://player.vimeo.com/video/${item.vimeoId}?title=0&byline=0&portrait=0&dnt=1`}
            title={item.title}
            loading="lazy"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    )}

    <!-- narrative body -->
    <div class="nd-body">
      {paragraphs.map((p) => <p>{p}</p>)}
      {item.sourceUrl && (
        <a class="nd-source" href={item.sourceUrl} target="_blank" rel="noopener noreferrer">view the original →</a>
      )}
    </div>

    <!-- outbound links (e.g. projects featured in a publication) -->
    {item.links && item.links.length > 0 && (
      <nav class="nd-links">
        {item.links.map((l) => (
          <a class="nd-link" href={l.url} target="_blank" rel="noopener noreferrer">
            <span>{l.label}</span><span class="nd-link-arrow">↗</span>
          </a>
        ))}
      </nav>
    )}

    <!-- media carousel (only when assets exist) -->
    {item.gallery && item.gallery.length > 0 && (
      <section class="nd-carousel-stage" data-count={item.gallery.length}>
        <div class="nd-carousel">
          <div class="nd-track">
            {item.gallery.map((src) => (
              <div class="nd-slide"><img src={src} alt={item.title} loading="lazy" /></div>
            ))}
          </div>
        </div>
        {item.gallery.length > 1 && (
          <div class="nd-controls">
            <button type="button" class="nd-prev">&larr; prev</button>
            <span class="nd-counter"><span class="nd-index">1</span> / {item.gallery.length}</span>
            <button type="button" class="nd-next">next &rarr;</button>
          </div>
        )}
      </section>
    )}

    <a class="nd-back" href="/news">&larr; news</a>
  </article>

  <footer class="site-footer">
    <a class="brand-logo-link" href="/" aria-label="jka — home">
      <img src="/jka-monogram.png" alt="jka" class="brand-logo footer" />
    </a>
    <a class="trace" href="mailto:mail@jihadk.com">mail@jihadk.com</a>
    <nav class="footer-social" aria-label="social links">
      <a href="https://instagram.com/jihadkhairallaharchitects" target="_blank" rel="noopener noreferrer" aria-label="instagram"><img src="/icon-instagram.png" alt="" class="social-icon" /></a>
      <a href="https://facebook.com/jihadkhairallaharchitects" target="_blank" rel="noopener noreferrer" aria-label="facebook"><img src="/icon-facebook.png" alt="" class="social-icon" /></a>
      <a href="https://linkedin.com/in/jihadkhairallah" target="_blank" rel="noopener noreferrer" aria-label="linkedin"><img src="/icon-linkedin.png" alt="" class="social-icon" /></a>
    </nav>
    <span class="trace copyright">&copy; 1998-<span class="year">{new Date().getFullYear()}</span> by jihad khairallah architects</span>
  </footer>

  <style>
    /* ===== news detail — scoped to this page ===== */
    .nd { max-width: 100%; }

    /* headline */
    .nd-head { text-align: center; padding: clamp(120px, 20vh, 230px) var(--inset) 0; }
    .nd-eyebrow {
      display: flex; justify-content: center; align-items: baseline; gap: 12px;
      font-size: var(--type-trace); letter-spacing: 0.12em; color: var(--trace);
      margin-bottom: 26px;
    }
    .nd-dot { opacity: 0.5; }
    .nd-title {
      font-size: clamp(1.3rem, 2.6vw, 2.1rem); font-weight: 300; letter-spacing: 0.03em;
      line-height: 1.3; color: var(--ink); margin: 0 auto; max-width: 18ch;
    }

    /* narrative body — centred block, deep side margins */
    .nd-body {
      max-width: 620px; margin: clamp(48px, 8vh, 96px) auto 0;
      padding: 0 var(--inset); text-align: center;
    }
    .nd-body p {
      font-size: clamp(0.95rem, 1.15vw, 1.05rem); line-height: 1.95;
      color: var(--ink-soft); margin: 0 0 1.5em;
    }
    .nd-source {
      display: inline-block; margin-top: 8px;
      font-size: var(--type-trace); letter-spacing: 0.1em; color: var(--trace);
      transition: color 0.3s ease;
    }
    .nd-source:hover { color: var(--ink); }

    /* outbound link index — featured projects */
    .nd-links { max-width: 620px; margin: clamp(40px, 6vh, 76px) auto 0; padding: 0 var(--inset); display: flex; flex-direction: column; }
    .nd-link {
      display: flex; justify-content: space-between; align-items: baseline; gap: 24px;
      padding: 18px 2px; border-top: 1px solid var(--trace);
      color: var(--ink-soft); text-decoration: none; font-weight: 300;
      transition: color 0.35s ease;
    }
    .nd-link:last-child { border-bottom: 1px solid var(--trace); }
    .nd-link:hover { color: var(--ink); }
    .nd-link-arrow { color: var(--trace); transition: color 0.35s ease; }
    .nd-link:hover .nd-link-arrow { color: var(--ink); }

    /* embedded film — responsive 16:9 */
    .nd-video { max-width: 1100px; margin: clamp(56px, 9vh, 110px) auto 0; padding: 0 var(--inset); }
    .nd-video-frame { position: relative; width: 100%; aspect-ratio: 16 / 9; overflow: hidden; background: var(--plate); }
    .nd-video-frame iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }

    /* carousel stage */
    .nd-carousel-stage { margin: clamp(64px, 11vh, 132px) auto 0; max-width: 1100px; padding: 0 var(--inset); }
    .nd-carousel { position: relative; overflow: hidden; }            /* the frame mask */
    .nd-track { display: flex; transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1); }
    .nd-slide {
      flex: 0 0 100%; height: clamp(48vh, 66vh, 78vh);
      display: flex; align-items: center; justify-content: center;
      background: var(--plate);
    }
    .nd-slide img { max-width: 100%; max-height: 100%; object-fit: contain; display: block; } /* sharp, uncropped */

    .nd-controls {
      display: flex; justify-content: space-between; align-items: baseline;
      margin-top: 22px;
    }
    .nd-prev, .nd-next, .nd-counter { font-size: var(--type-trace); letter-spacing: 0.12em; color: var(--trace); }
    .nd-prev, .nd-next {
      background: none; border: 0; cursor: pointer; padding: 4px 0; font: inherit;
      text-transform: lowercase; letter-spacing: 0.12em; transition: color 0.3s ease;
    }
    .nd-prev:hover, .nd-next:hover { color: var(--ink); }
    .nd-counter { letter-spacing: 0.08em; }

    /* back link */
    .nd-back {
      display: block; text-align: center; margin: clamp(64px, 11vh, 128px) auto 0;
      font-size: var(--type-trace); letter-spacing: 0.12em; color: var(--trace);
      transition: color 0.3s ease;
    }
    .nd-back:hover { color: var(--ink); }
  </style>

  <script>
    const stage = document.querySelector(".nd-carousel-stage");
    if (stage) {
      const track = stage.querySelector(".nd-track");
      const slides = stage.querySelectorAll(".nd-slide");
      const prev = stage.querySelector(".nd-prev");
      const next = stage.querySelector(".nd-next");
      const indexEl = stage.querySelector(".nd-index");
      const total = slides.length;
      let i = 0;

      const render = () => {
        track.style.transform = `translateX(-${i * 100}%)`;
        if (indexEl) indexEl.textContent = String(i + 1);
      };
      const go = (n) => { i = (n + total) % total; render(); };

      prev && prev.addEventListener("click", () => go(i - 1));
      next && next.addEventListener("click", () => go(i + 1));

      // touch swipe
      let startX = 0;
      stage.addEventListener("touchstart", (e) => { startX = e.touches[0].clientX; }, { passive: true });
      stage.addEventListener("touchend", (e) => {
        const dx = e.changedTouches[0].clientX - startX;
        if (Math.abs(dx) > 40) go(dx < 0 ? i + 1 : i - 1);
      }, { passive: true });

      // keyboard
      document.addEventListener("keydown", (e) => {
        if (e.key === "ArrowLeft") go(i - 1);
        if (e.key === "ArrowRight") go(i + 1);
      });
    }
  </script>
</Base>
