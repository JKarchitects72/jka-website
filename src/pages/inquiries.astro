    <div></div>
  </section>
  <div class="silence-major"></div>
  <div class="commission-mail settle"><a href="mailto:mail@jihadk.com">mail@jihadk.com</a></div>
  <div class="commission-trace settle">riverside 2404, sin el fil, beirut · est. 1998<br>+961 3 111 354</div>
  <div class="silence-module"></div>
