---
import Base from "../layouts/Base.astro";
import { news } from "../data/news";

const filters = ["news", "exhibition", "media", "award"];
const dateRange = (a, b) => (b ? `${a} - ${b}` : a);
---
<Base title="news — jihad khairallah architects"
      description="press, exhibitions, awards, and announcements from jihad khairallah architects.">
  <section class="news-head">
    <h1 class="news-masthead">news</h1>
    <nav class="news-filters" aria-label="news categories">
      {filters.map((f) => (
        <button type="button" class:list={["news-filter", { active: f === "news" }]} data-filter={f}>{f}</button>
      ))}
    </nav>
  </section>

  <section class="news-grid">
    {news.map((item) => (
      <a
        class="news-card"
        data-category={item.category}
        href={`/news/${item.slug}`}
      >
        <div class="news-thumb">
          {item.image
            ? <img class="news-img" src={item.image} alt={item.title} loading="lazy" />
            : <span class="plate-label">[ {item.title} ]</span>}
        </div>
        <div class="news-meta">
          <div class="news-line-top">
            <span class="news-cat">{item.category}</span>
            {item.dateStart && <span class="news-date">{dateRange(item.dateStart, item.dateEnd)}</span>}
          </div>
          <div class="news-card-title">{item.title}</div>
          <div class="news-desc">{item.description}</div>
        </div>
      </a>
    ))}
  </section>

  <div class="silence-module"></div>
  <a class="commission-line" href="/inquiries"><span>commission an enquiry</span><span>→</span></a>

  <footer class="site-footer">
    <a class="brand-logo-link" href="/" aria-label="jka — home">
      <img src="/jka-monogram.png" alt="jka" class="brand-logo footer" />
    </a>
    <a class="trace" href="mailto:mail@jihadk.com">mail@jihadk.com</a>
    <nav class="footer-social" aria-label="social links">
      <a href="https://instagram.com/jihadkhairallaharchitects" target="_blank" rel="noopener noreferrer" aria-label="instagram"><img src="/icon-instagram.png" alt="" class="social-icon" /></a>
      <a href="https://facebook.com/jihadkhairallaharchitects" target="_blank" rel="noopener noreferrer" aria-label="facebook"><img src="/icon-facebook.png" alt="" class="social-icon" /></a>
      <a href="https://linkedin.com/in/jihadkhairallah" target="_blank" rel="noopener noreferrer" aria-label="linkedin"><img src="/icon-linkedin.png" alt="" class="social-icon" /></a>
    </nav>
    <span class="trace copyright">&copy; 1998-<span class="year">{new Date().getFullYear()}</span> by jihad khairallah architects</span>
  </footer>

  <style>
    /* ===== news — scoped to this page ===== */

    /* title + filters */
    .news-head { text-align: center; padding: clamp(104px, 17vh, 200px) var(--inset) 0; }
    .news-masthead {
      font-size: clamp(1.1rem, 1.7vw, 1.5rem);
      font-weight: 300; letter-spacing: 0.05em; color: var(--ink); margin: 0;
    }
    .news-filters {
      display: flex; justify-content: center; flex-wrap: wrap;
      gap: clamp(20px, 4vw, 56px); margin-top: 30px;
    }
    .news-filter {
      background: none; border: 0; cursor: pointer; padding: 6px 0;
      font: inherit; font-size: var(--type-trace); letter-spacing: 0.12em;
      color: var(--trace); text-transform: lowercase; transition: color 0.3s ease;
    }
    .news-filter:hover, .news-filter.active { color: var(--ink); }

    /* the 3-column zero-gap matrix */
    .news-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
      max-width: 1180px;
      margin: clamp(48px, 8vh, 104px) auto 0;
      padding: 0 var(--inset);
    }
    .news-card { display: block; }
    .news-thumb {
      position: relative; aspect-ratio: 4 / 3; overflow: hidden;
      background: var(--plate);
    }
    .news-img {
      position: absolute; inset: 0; width: 100%; height: 100%;
      object-fit: cover;
      transition: filter 0.6s ease, transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .news-card:hover .news-img { transform: scale(1.04); }
    .news-thumb .plate-label {
      position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
      font-size: var(--type-trace); letter-spacing: 0.1em; color: var(--trace);
      text-align: center; padding: 0 14px;
    }

    /* permanent under-card text, left-aligned to the thumbnail edge */
    .news-meta { text-align: left; padding: 14px 0 34px; }
    .news-line-top {
      display: flex; justify-content: space-between; align-items: baseline; gap: 12px;
    }
    .news-cat { font-size: var(--type-trace); letter-spacing: 0.1em; color: var(--trace); }
    .news-date { font-size: var(--type-trace); letter-spacing: 0.05em; color: var(--trace); white-space: nowrap; }
    .news-card-title {
      font-size: clamp(0.85rem, 1.1vw, 0.98rem); letter-spacing: 0.02em;
      color: var(--ink); margin: 9px 0 5px;
    }
    .news-desc { font-size: var(--type-trace); line-height: 1.65; color: var(--ink-soft); }

    /* responsive */
    @media (max-width: 900px) { .news-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 560px) { .news-grid { grid-template-columns: 1fr; } }
  </style>

  <script>
    const filterBtns = Array.from(document.querySelectorAll(".news-filter"));
    const cards = Array.from(document.querySelectorAll(".news-card"));
    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const f = btn.getAttribute("data-filter");
        filterBtns.forEach((b) => b.classList.toggle("active", b === btn));
        cards.forEach((c) => {
          const show = f === "news" || c.getAttribute("data-category") === f;
          c.style.display = show ? "" : "none";
        });
      });
    });
  </script>
</Base>
