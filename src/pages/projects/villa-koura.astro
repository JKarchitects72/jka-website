---
import Base from "../../layouts/Base.astro";
---
<Base title="villa koura — jka">
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  "name": "Villa Koura",
  "creator": { "@type": "Organization", "name": "Jihad Khairallah Architects" },
  "dateCreated": "2017",
  "locationCreated": { "@type": "Place", "name": "Koura, North Lebanon" },
  "material": ["fair-faced white plaster", "structural glazing", "natural oak", "honed grey stone"],
  "about": "a 350 sqm private residence; minimalist white volumes over the northern lebanese coast."
}) } />
  <section class="cms-project-hero">
    <span class="hero-media-note">[ hero still — the white monolith, entrance slot centred ]</span>
    <div class="hero-title-block">
      <h1 class="project-title">villa koura</h1>
      <p class="project-meta">residential — koura, north lebanon — 2017 — 350 sqm</p>
    </div>
  </section>
  <div class="silence-module"></div>
  <section class="cms-narrative settle">
    <p class="narrative-text">villa koura rests on a lebanese hill, its gaze fixed on the northern sea. bedrooms settle into the earth; living volumes rise toward the light. white is not colour here but a stage for shadow. envelope and interior were never drawn apart — one body, one authorship, one quiet argument for what remains when nothing is unnecessary.</p>
    <div></div>
  </section>
  <div class="silence-module"></div>
  <section class="cms-plate short settle"><span class="plate-label">[ interior-to-sea frame — oak partition, glazing, horizon ]</span></section>
  <div style="height:2px"></div>
  <section class="cms-diptych-row settle">
    <div class="cms-plate"><span class="plate-label">[ living volume — black seating against white ]</span></div>
    <div class="cms-plate"><span class="plate-label">[ kitchen volume — single white mass ]</span></div>
  </section>
  <div class="silence-module"></div>
  <section class="cms-material-strip settle">
    <figure><div class="material-crop"><span class="plate-label">[ crop ]</span></div><figcaption>fair-faced white plaster</figcaption></figure>
    <figure><div class="material-crop"><span class="plate-label">[ crop ]</span></div><figcaption>natural oak</figcaption></figure>
    <figure><div class="material-crop"><span class="plate-label">[ crop ]</span></div><figcaption>honed grey stone</figcaption></figure>
  </section>
  <div class="silence-module"></div>
  <section class="cms-object-datum settle">
    <div>
      <span class="eyebrow">object</span>
      <div class="object-name">the borges table</div>
      <a class="object-link" href="/object">conceived for this room — part of kozo →</a>
    </div>
    <div class="object-plate"><span class="plate-label">[ object photograph — large ]</span></div>
  </section>
  <a class="cms-terminus" href="/projects/villa-hariss"><span>next — villa hariss</span><span>→</span></a>
  <a class="commission-line" href="/commission"><span>commission an enquiry</span><span>→</span></a>
  <footer class="site-footer">
    <a class="brand-logo-link" href="/" aria-label="jka — home">
      <img src="/jka-monogram.png" alt="jka" class="brand-logo footer" />
    </a>
    <a class="trace" href="mailto:mail@jihadk.com">mail@jihadk.com</a>
    <nav class="footer-social" aria-label="social links">
      <a href="https://instagram.com/jihadkhairallaharchitects" target="_blank" rel="noopener noreferrer" aria-label="instagram">
        <img src="/icon-instagram.png" alt="" class="social-icon" />
      </a>
      <a href="https://facebook.com/jihadkhairallaharchitects" target="_blank" rel="noopener noreferrer" aria-label="facebook">
        <img src="/icon-facebook.png" alt="" class="social-icon" />
      </a>
      <a href="https://linkedin.com/in/jihadkhairallah" target="_blank" rel="noopener noreferrer" aria-label="linkedin">
        <img src="/icon-linkedin.png" alt="" class="social-icon" />
      </a>
    </nav>
    <span class="trace copyright">© jka — beirut, est. 1998</span>
  </footer>
</Base>