---
import Base from "../../layouts/Base.astro";
---
<Base title="villa hariss — jka">
  <section class="cms-project-hero">
    <span class="hero-media-note">[ video hero — light crossing sandstone & timber ]</span>
    <div class="hero-title-block">
      <h1 class="project-title">villa hariss</h1>
      <p class="project-meta">residential — hariss, lebanon — 2019</p>
    </div>
  </section>
  <div class="silence-module"></div>
  <section class="cms-narrative settle">
    <p class="narrative-text">villa hariss steps down a lebanese ridge, reading the land rather than resisting it. a sandstone mass, a timber upper volume, and a perforated stone screen layer against the mountain light. through punctured walls and slatted timber, the sun is filtered, not admitted — drawn across the floors as a shifting mural. the house breathes with the breeze, porous between inside and landscape.</p>
    <div></div>
  </section>
  <div class="silence-module"></div>
  <section class="cms-plate short settle"><span class="plate-label">[ establishing plate — front elevation, three material layers ]</span></section>
  <div style="height:2px"></div>
  <section class="cms-diptych-row settle">
    <div class="cms-plate"><span class="plate-label">[ brise-soleil fins — timber against stone ]</span></div>
    <div class="cms-plate"><span class="plate-label">[ cantilevered volume over the pool terrace ]</span></div>
  </section>
  <div style="height:2px"></div>
  <section class="cms-plate short settle"><span class="plate-label">[ threshold plate — entry hall, floating stair, lattice window ]</span></section>
  <div style="height:2px"></div>
  <section class="cms-diptych-row settle">
    <div class="cms-plate"><span class="plate-label">[ double-height dining, filtered light ]</span></div>
    <div class="cms-plate"><span class="plate-label">[ living volume toward terrace & stair ]</span></div>
  </section>
  <div style="height:2px"></div>
  <section class="cms-plate short settle"><span class="plate-label">[ the light mural — striped shadow across the upper lounge ]</span></section>
  <div class="silence-module"></div>
  <section class="cms-material-strip settle">
    <figure><div class="material-crop"><span class="plate-label">[ crop ]</span></div><figcaption>stacked sandstone</figcaption></figure>
    <figure><div class="material-crop"><span class="plate-label">[ crop ]</span></div><figcaption>dark timber screen</figcaption></figure>
    <figure><div class="material-crop"><span class="plate-label">[ crop ]</span></div><figcaption>perforated stone lattice</figcaption></figure>
  </section>
  <div class="silence-module"></div>
  <section class="cms-object-datum settle">
    <div>
      <span class="eyebrow">object</span>
      <div class="object-name">the faceted cabinet</div>
      <a class="object-link" href="/object">bespoke lacquered joinery, authored for this volume →</a>
    </div>
    <div class="object-plate"><span class="plate-label">[ cabinet in the living volume ]</span></div>
  </section>
  <div class="silence-module"></div>
  <section class="cms-plate short settle"><span class="plate-label">[ landscape terminus — the house held in its ridge ]</span></section>
  <a class="cms-terminus" href="/projects/villa-koura"><span>next — villa koura</span><span>→</span></a>
  <a class="commission-line" href="/commission"><span>commission an enquiry</span><span>→</span></a>
  <footer class="site-footer">
    <a class="brand-logo-link" href="/" aria-label="jka — home">
      <img src="/jka-monogram.png" alt="jka" class="brand-logo footer" />
    </a>
    <a class="trace" href="mailto:mail@jihadk.com">mail@jihadk.com</a>
    <nav class="footer-social" aria-label="social links">
      <a href="https://instagram.com/jihadkhairallaharchitects" target="_blank" rel="noopener noreferrer" aria-label="instagram">
        <img src="/icon-instagram.png" alt="" class="social-icon" />
      </a>
      <a href="https://facebook.com/jihadkhairallaharchitects" target="_blank" rel="noopener noreferrer" aria-label="facebook">
        <img src="/icon-facebook.png" alt="" class="social-icon" />
      </a>
      <a href="https://linkedin.com/in/jihadkhairallah" target="_blank" rel="noopener noreferrer" aria-label="linkedin">
        <img src="/icon-linkedin.png" alt="" class="social-icon" />
      </a>
    </nav>
    <span class="trace copyright">© jka — beirut, est. 1998</span>
  </footer>
</Base>