---
import Base from "../../layouts/Base.astro";
import { allForGrid, projectHref } from "../../data/projects";
const thumbFor = (p) => p.heroImage ?? p.photos?.find((ph) => ph.src)?.src ?? null;
---
<Base title="projects — jihad khairallah architects"
      description="the complete body of work — residential, workplace, retail, and conceptual projects by jka, beirut, since 1998.">
  <div class="projects-head"></div>
  <nav class="projects-filters" aria-label="project disciplines">
    <button type="button" class:list={["projects-filter", { active: true }]} data-filter="all">all</button>
    <button type="button" class="projects-filter" data-filter="architecture">architecture</button>
    <button type="button" class="projects-filter" data-filter="interior architecture">interior architecture</button>
  </nav>
  <div class="projects-grid-wrap">
  <section class="projects-grid settle">
    {allForGrid.map((p) => (
      <a class="project-card" href={projectHref(p)} aria-label={p.name} data-discipline={(p.discipline ?? []).join("|")}>
        <div class="image-wrapper">
          {thumbFor(p)
            ? <img class="project-thumbnail" src={thumbFor(p)} alt={p.name} loading="lazy" />
            : <span class="plate-label">[ {p.name} ]</span>}
        </div>
        <div class="caption-reveal">
          <span class="project-meta-text">{[p.name, p.location, p.year].filter(Boolean).join(", ")}</span>
        </div>
      </a>
    ))}
  </section>
  </div>
  <div class="silence-module"></div>
  <a class="commission-line" href="/inquiries"><span>commission an enquiry</span><span>→</span></a>
  <footer class="site-footer">
    <a class="brand-logo-link" href="/" aria-label="jka — home">
      <img src="/jka-monogram.png" alt="jka" class="brand-logo footer" />
    </a>
    <a class="trace" href="mailto:mail@jihadk.com">mail@jihadk.com</a>
    <nav class="footer-social" aria-label="social links">
      <a href="https://instagram.com/jihadkhairallaharchitects" target="_blank" rel="noopener noreferrer" aria-label="instagram"><img src="/icon-instagram.png" alt="" class="social-icon" /></a>
      <a href="https://facebook.com/jihadkhairallaharchitects" target="_blank" rel="noopener noreferrer" aria-label="facebook"><img src="/icon-facebook.png" alt="" class="social-icon" /></a>
      <a href="https://linkedin.com/in/jihadkhairallah" target="_blank" rel="noopener noreferrer" aria-label="linkedin"><img src="/icon-linkedin.png" alt="" class="social-icon" /></a>
    </nav>
    <span class="trace copyright">&copy; 1998-<span class="year">{new Date().getFullYear()}</span> by jihad khairallah architects</span>
  </footer>

  <script>
    const filterBtns = Array.from(document.querySelectorAll(".projects-filter"));
    const cards = Array.from(document.querySelectorAll(".project-card"));
    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const f = btn.getAttribute("data-filter");
        filterBtns.forEach((b) => b.classList.toggle("active", b === btn));
        cards.forEach((c) => {
          const d = (c.getAttribute("data-discipline") || "").split("|");
          const show = f === "all" || d.includes(f);
          c.style.display = show ? "" : "none";
        });
      });
    });
  </script>
</Base>

<style>
  /* discipline filter — mirrors the news filter chips */
  .projects-filters {
    display: flex; justify-content: center; flex-wrap: wrap;
    gap: clamp(20px, 4vw, 56px); margin-top: 30px;
  }
  .projects-filter {
    background: none; border: 0; cursor: pointer; padding: 6px 0;
    font: inherit; font-size: var(--type-trace); letter-spacing: 0.12em;
    color: var(--trace); text-transform: lowercase; transition: color 0.3s ease;
  }
  .projects-filter:hover, .projects-filter.active { color: var(--ink); }

  /* projects — airy square grid.
     gap = half a thumbnail, held at every width via container-query units:
     with N columns and gap = padding = cell/2, cell = 2W/(3N+1), so gap = W/(3N+1).
     N=3 -> 10cqw,  N=2 -> ~14.29cqw. */
  .projects-grid-wrap { container-type: inline-size; }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10cqw;        /* inner gutters = half a cell */
    padding: 10cqw;    /* outer gutters = half a cell */
  }

  /* card is the positioned frame; the caption floats beneath it into the gutter */
  .project-card { position: relative; }

  /* perfect square cells; image cover-crops centered, hover zoom stays frame-masked */
  .image-wrapper { aspect-ratio: 1 / 1; }
  .image-wrapper::after { content: none; }   /* drop the old hover scrim */

  /* (1)(2) monochrome facade by default; full colour on hover,
     weightless 0.6s filter curve riding alongside the existing frame-zoom */
  .project-thumbnail {
    filter: grayscale(100%);
    transition: filter 0.6s ease, transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .project-card:hover .project-thumbnail { filter: grayscale(0%); }

  /* (3) metadata hidden, then scrolls down from behind the frame's lower edge.
     absolutely positioned + clipped, so it never reflows the grid */
  .caption-reveal {
    position: absolute;
    top: calc(100% + 10px);   /* tucked just beneath the square */
    left: 0;
    width: 100%;
    overflow: hidden;          /* the boundary mask the text emerges from */
    pointer-events: none;
  }
  .project-meta-text {
    display: block;
    max-width: 50%;            /* (4) never wider than half the card; long names stack */
    color: var(--ink);
    text-align: left;
    overflow-wrap: break-word;
    transform: translateY(-110%);   /* clipped, tucked up behind the frame */
    opacity: 0;
    transition: transform 0.6s ease, opacity 0.6s ease;
  }
  .project-card:hover .project-meta-text { transform: translateY(0); opacity: 1; }

  /* touch devices have no hover: full colour + a static, readable caption */
  @media (hover: none) {
    .project-thumbnail { filter: grayscale(0%); }
    .caption-reveal { position: static; margin-top: 10px; overflow: visible; }
    .project-meta-text { transform: none; opacity: 1; max-width: 100%; }
  }

  /* respect reduced-motion: keep the reveal, drop the animation */
  @media (prefers-reduced-motion: reduce) {
    .project-thumbnail, .project-meta-text { transition: none; }
  }

  @media (max-width: 1024px) {
    .projects-grid { grid-template-columns: repeat(2, 1fr); gap: 14.2857cqw; padding: 14.2857cqw; }
  }
  @media (max-width: 640px) {
    /* single column, comfortably sized rather than a literal half-width card */
    .projects-grid { grid-template-columns: 1fr; gap: 7cqw; padding: 7cqw; }
  }
</style>