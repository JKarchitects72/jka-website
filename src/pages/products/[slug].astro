---
import Base from "../../layouts/Base.astro";
import { products } from "../../data/products";

export function getStaticPaths() {
  return products.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
const paragraphs = item.description.split("\n\n");
---
<Base title={`${item.name} — jihad khairallah architects`} description={item.description}>
  <article class="pd">
    <!-- headline -->
    <header class="pd-head">
      {item.tagline && <div class="pd-eyebrow">{item.tagline}</div>}
      <h1 class="pd-title">{item.name}</h1>
    </header>

    <!-- narrative body -->
    <div class="pd-body">
      {paragraphs.map((p) => <p>{p}</p>)}
    </div>

    <!-- media carousel (only when assets exist) -->
    {item.gallery && item.gallery.length > 0 && (
      <section class="pd-carousel-stage" data-count={item.gallery.length}>
        <div class="pd-carousel">
          <div class="pd-track">
            {item.gallery.map((src) => (
              <div class="pd-slide"><img src={src} alt={item.name} loading="lazy" /></div>
            ))}
          </div>
        </div>
        {item.gallery.length > 1 && (
          <div class="pd-controls">
            <button type="button" class="pd-prev">&larr; prev</button>
            <span class="pd-counter"><span class="pd-index">1</span> / {item.gallery.length}</span>
            <button type="button" class="pd-next">next &rarr;</button>
          </div>
        )}
      </section>
    )}

    <a class="pd-back" href="/products">&larr; products</a>
  </article>

  <footer class="site-footer">
    <a class="brand-logo-link" href="/" aria-label="jka — home">
      <img src="/jka-monogram.png" alt="jka" class="brand-logo footer" />
    </a>
    <a class="trace" href="mailto:mail@jihadk.com">mail@jihadk.com</a>
    <nav class="footer-social" aria-label="social links">
      <a href="https://instagram.com/jihadkhairallaharchitects" target="_blank" rel="noopener noreferrer" aria-label="instagram"><img src="/icon-instagram.png" alt="" class="social-icon" /></a>
      <a href="https://facebook.com/jihadkhairallaharchitects" target="_blank" rel="noopener noreferrer" aria-label="facebook"><img src="/icon-facebook.png" alt="" class="social-icon" /></a>
      <a href="https://linkedin.com/in/jihadkhairallah" target="_blank" rel="noopener noreferrer" aria-label="linkedin"><img src="/icon-linkedin.png" alt="" class="social-icon" /></a>
    </nav>
    <span class="trace copyright">&copy; 1998-<span class="year">{new Date().getFullYear()}</span> by jihad khairallah architects</span>
  </footer>

  <style>
    /* ===== product detail — mirrors the news detail layout ===== */
    .pd { max-width: 100%; }

    /* headline */
    .pd-head { text-align: center; padding: clamp(120px, 20vh, 230px) var(--inset) 0; }
    .pd-eyebrow {
      font-size: var(--type-trace); letter-spacing: 0.16em; text-transform: lowercase;
      color: var(--trace); margin-bottom: 26px;
    }
    .pd-title {
      font-size: clamp(1.3rem, 2.6vw, 2.1rem); font-weight: 300; letter-spacing: 0.03em;
      line-height: 1.3; color: var(--ink); margin: 0 auto; max-width: 18ch;
    }

    /* narrative body — centred block, deep side margins */
    .pd-body {
      max-width: 620px; margin: clamp(48px, 8vh, 96px) auto 0;
      padding: 0 var(--inset); text-align: center;
    }
    .pd-body p {
      font-size: clamp(0.95rem, 1.15vw, 1.05rem); line-height: 1.95;
      color: var(--ink-soft); margin: 0 0 1.5em;
    }

    /* carousel stage */
    .pd-carousel-stage { margin: clamp(64px, 11vh, 132px) auto 0; max-width: 1100px; padding: 0 var(--inset); }
    .pd-carousel { position: relative; overflow: hidden; }            /* the frame mask */
    .pd-track { display: flex; transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1); }
    .pd-slide {
      flex: 0 0 100%; height: clamp(48vh, 66vh, 78vh);
      display: flex; align-items: center; justify-content: center;
      background: var(--plate);
    }
    .pd-slide img { max-width: 100%; max-height: 100%; object-fit: contain; display: block; } /* sharp, uncropped */

    .pd-controls {
      display: flex; justify-content: space-between; align-items: baseline;
      margin-top: 22px;
    }
    .pd-prev, .pd-next, .pd-counter { font-size: var(--type-trace); letter-spacing: 0.12em; color: var(--trace); }
    .pd-prev, .pd-next {
      background: none; border: 0; cursor: pointer; padding: 4px 0; font: inherit;
      text-transform: lowercase; letter-spacing: 0.12em; transition: color 0.3s ease;
    }
    .pd-prev:hover, .pd-next:hover { color: var(--ink); }
    .pd-counter { letter-spacing: 0.08em; }

    /* back link */
    .pd-back {
      display: block; text-align: center; margin: clamp(64px, 11vh, 128px) auto 0;
      font-size: var(--type-trace); letter-spacing: 0.12em; color: var(--trace);
      transition: color 0.3s ease;
    }
    .pd-back:hover { color: var(--ink); }
  </style>

  <script>
    const stage = document.querySelector(".pd-carousel-stage");
    if (stage) {
      const track = stage.querySelector(".pd-track");
      const slides = stage.querySelectorAll(".pd-slide");
      const prev = stage.querySelector(".pd-prev");
      const next = stage.querySelector(".pd-next");
      const indexEl = stage.querySelector(".pd-index");
      const total = slides.length;
      let i = 0;

      const render = () => {
        track.style.transform = `translateX(-${i * 100}%)`;
        if (indexEl) indexEl.textContent = String(i + 1);
      };
      const go = (n) => { i = (n + total) % total; render(); };

      prev && prev.addEventListener("click", () => go(i - 1));
      next && next.addEventListener("click", () => go(i + 1));

      let startX = 0;
      stage.addEventListener("touchstart", (e) => { startX = e.touches[0].clientX; }, { passive: true });
      stage.addEventListener("touchend", (e) => {
        const dx = e.changedTouches[0].clientX - startX;
        if (Math.abs(dx) > 40) go(dx < 0 ? i + 1 : i - 1);
      }, { passive: true });

      document.addEventListener("keydown", (e) => {
        if (e.key === "ArrowLeft") go(i - 1);
        if (e.key === "ArrowRight") go(i + 1);
      });
    }
  </script>
</Base>
