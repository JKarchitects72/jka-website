---
import Base from "../layouts/Base.astro";
---
<Base title="object & product — jka">
  <section class="object-intro">
    <div class="intro-silence settle">
      <p class="manifesto">each object leaves the same hand as the buildings, drawn from light, geometry, and the space it will inhabit.</p>
      <div class="object-id"><b>the faceted cabinet</b><br>bespoke archive — 2019</div>
    </div>
    <div class="pedestal"><div class="obj"></div></div>
  </section>
  <div class="silence-major"></div>
  <section class="cms-object-schema settle">
    <div class="schema-row"><span class="schema-key">object</span><span class="schema-val">the faceted cabinet</span></div>
    <div class="schema-row"><span class="schema-key">collection</span><span class="schema-val">bespoke archive</span></div>
    <div class="schema-row"><span class="schema-key">year</span><span class="schema-val">2019</span></div>
    <div class="schema-row"><span class="schema-key">materials</span><span class="schema-val">lacquered timber — oak carcass — mirror inlay</span></div>
  </section>
  <div class="silence-module"></div>
  <section class="cms-macro-plate settle"><span>[ macro — the lacquer facet meeting the oak edge ]</span></section>
  <div class="silence-module"></div>
  <a class="cms-provenance-link settle" href="/projects/villa-hariss"><span>manifested within <b>villa hariss</b></span><span>→</span></a>
  <div class="silence-module"></div>
  <section class="inquiry-protocol settle">
    <a class="inquiry-cta" href="mailto:mail@jihadk.com?subject=inquiry — the faceted cabinet"><span>inquire about this piece</span><span>→</span></a>
    <p class="inquiry-note">each piece is made to order or held in limited number. acquisition begins with a conversation with the beirut studio.</p>
  </section>
  <div class="silence-module"></div>
  <a class="commission-line" href="/projects"><span>view all projects</span><span>→</span></a>
  <footer class="site-footer">
    <a class="brand-logo-link" href="/" aria-label="jka — home">
      <img src="/jka-monogram.png" alt="jka" class="brand-logo footer" />
    </a>
    <a class="trace" href="mailto:mail@jihadk.com">mail@jihadk.com</a>
    <nav class="footer-social" aria-label="social links">
      <a href="https://instagram.com/jihadkhairallaharchitects" target="_blank" rel="noopener noreferrer" aria-label="instagram">
        <img src="/icon-instagram.png" alt="" class="social-icon" />
      </a>
      <a href="https://facebook.com/jihadkhairallaharchitects" target="_blank" rel="noopener noreferrer" aria-label="facebook">
        <img src="/icon-facebook.png" alt="" class="social-icon" />
      </a>
      <a href="https://linkedin.com/in/jihadkhairallah" target="_blank" rel="noopener noreferrer" aria-label="linkedin">
        <img src="/icon-linkedin.png" alt="" class="social-icon" />
      </a>
    </nav>
    <span class="trace copyright">© jka — beirut, est. 1998</span>
  </footer>
</Base>